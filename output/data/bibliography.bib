  title={Clinical experience suggests that modafinil is an effective and safe treatment for paediatric narcolepsy},
  author={Michel Lecendreux and Oliviero Bruni and Patricia Franco and Paul Gringras and Éric Konofal and Soňa Nevšímalová and Teresa Paiva and Markku Partinen and E Peeters and Rosa Peraita‐Adrados and Giuseppe Plazzi and Francesca Poli},
