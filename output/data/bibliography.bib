  title={Acute dilated cardiomyopathy and myocardial injury after combined 4-fluoroamphetamine and modafinil ingestion.},
  author={Carl E Wolf and Justin L Poklis and Kirk Cumpston and Michael Moss and Alphonse Poklis},
