@article{ballas2002modafinil,
  title={Modafinil: past, present and future},
  author={Christos Ballas and Deborah Kim and Claudia F. Baldassano and Nicholas Hoeh},
  journal={Expert Review of Neurotherapeutics},
  year={2002},
  doi={10.1586/14737175.2.4.449},
  abstract={Modafinil is a novel wake-promoting agent approved for the treatment of excessive sleepiness associated with narcolepsy that holds significant promise as an alternative treatment to traditional psychostimulants for excessive fatigue associated with medical and psychiatric disorders and as augmentation medication for treatment-resistant depression.}
