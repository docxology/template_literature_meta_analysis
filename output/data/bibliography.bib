@article{aiken2025modafinil,
  title={Modafinil, Omega-3, and Other Third-Line Options for Bipolar Depression},
  author={Chris Aiken},
  year={2025},
  doi={10.64239/pi-vl10010},
  abstract={When prescribing armodafinil for bipolar depression-related fatigue, a practical approach is to start with a dose of 50-150 mg and titrate up to 250 mg in the morning. Patients should be advised to stay out of bed as part of the behavioral component of the treatment. Coenzyme Q10 can be a helpful adjunct in bipolar depression, especially for patients with cognitive or energy complaints, as it targets mitochondrial dysfunction, supports cellular repair, and may improve energy and cognition with a favorable side-effect profile. Omega-3 supplements can provide multiple benefits for bipolar patients beyond depression improvement, including helping with medication side effects and addressing comorbid conditions such as dyslipidemia.}
